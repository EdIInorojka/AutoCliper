# StreamCuter Environment Variables (optional)
# Copy to .env and fill in values.

# Path to ffmpeg binaries (if not in PATH)
# FFMPEG_PATH=C:\ffmpeg\bin

# Path to Whisper model cache
# WHISPER_CACHE_DIR=C:\Users\You\.cache\whisper

# Optional faster-whisper model override for smoke tests: tiny/base/small/medium/large-v3
# STREAMCUTER_WHISPER_MODEL=tiny

# HuggingFace token (for faster-whisper model download)
# HF_TOKEN=

# OpenAI API key (if using OpenAI Whisper API instead of local)
# OPENAI_API_KEY=
